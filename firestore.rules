rules_version = '2';
// 開発・少人数テスト向け。本番ではルーム参加の検証・レート制限・課金監視と合わせて強化してください。
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMemberOwner(memberId) {
      return signedIn() && request.auth.uid == memberId;
    }

    function validMemberPresence() {
      return request.resource.data.keys().hasOnly([
        'nickname',
        'role',
        'reportedAtUtc',
        'proximityBand',
        'locationVisibility'
      ]);
    }

    match /rooms/{roomId}/members/{memberId} {
      // プレゼンス同期: 自分のドキュメントだけ書き換え。live 座標は members に保存しない。
      allow read: if signedIn();
      allow create, update: if isMemberOwner(memberId) && validMemberPresence();
      allow delete: if isMemberOwner(memberId);
    }
  }
}
