rules_version = '2';
// ONI PIN — Firestore security rules (少人数テスト向け)
// デプロイ: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Shared helpers ───────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }

    function isMemberOwner(memberId) {
      return signedIn() && request.auth.uid == memberId;
    }

    function isRoomHost() {
      return signedIn()
        && resource.data.hostUid == request.auth.uid;
    }

    function onlyKeysChanged(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    function memberDocPath(roomId, memberId) {
      return /databases/$(database)/documents/rooms/$(roomId)/members/$(memberId);
    }

    function memberExists(roomId, memberId) {
      return exists(memberDocPath(roomId, memberId));
    }

    function memberRole(roomId, memberId) {
      return get(memberDocPath(roomId, memberId)).data.role;
    }

    function roomExists(roomId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId));
    }

    function roomHostUid(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data.hostUid;
    }

    function isRoomParticipant(roomId) {
      return signedIn()
        && memberExists(roomId, request.auth.uid)
        && memberRole(roomId, request.auth.uid) != 'spectator';
    }

    function isRoomSpectator(roomId) {
      return signedIn()
        && memberExists(roomId, request.auth.uid)
        && memberRole(roomId, request.auth.uid) == 'spectator';
    }

    function roomPhaseRunning(roomId) {
      return roomExists(roomId)
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.phase == 'running';
    }

    // ─── Room document (Host authority + Match end rescue) ─────────────
    function validRoomCreate() {
      return request.resource.data.keys().hasOnly(['hostUid', 'phase'])
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.phase == 'lobby';
    }

    function validHostRoomUpdate() {
      return isRoomHost()
        && onlyKeysChanged([
          'hostUid',
          'phase',
          'endedAtUtc',
          'endReason',
          'matchOutcome',
          'endMessage',
          'matchStart',
          'lobbyPlayArea',
          'lobbyPlayAreaSlotName'
        ]);
    }

    function claimEmptyHost() {
      return signedIn()
        && (resource.data.hostUid == null || resource.data.hostUid == '')
        && request.resource.data.hostUid == request.auth.uid
        && onlyKeysChanged(['hostUid']);
    }

    // Host takeover: client detects stale host, participant claims hostUid.
    function claimAbsentHost() {
      return signedIn()
        && resource.data.hostUid != request.auth.uid
        && request.resource.data.hostUid == request.auth.uid
        && onlyKeysChanged(['hostUid']);
    }

    // Match end rescue: non-host may end when host is background/stale (time_up / all_humans_eliminated).
    function validMatchEndRescueUpdate(roomId) {
      return isRoomParticipant(roomId)
        && resource.data.phase == 'running'
        && request.resource.data.phase == 'ended'
        && request.auth.uid != resource.data.hostUid
        && onlyKeysChanged([
          'phase',
          'endedAtUtc',
          'endReason',
          'matchOutcome',
          'endMessage',
        ])
        && (request.resource.data.endReason == 'time_up'
            || request.resource.data.endReason == 'all_humans_eliminated'
            || request.resource.data.endReason == 'oni_eliminated');
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn() && validRoomCreate();
      allow update: if validHostRoomUpdate()
        || claimEmptyHost()
        || claimAbsentHost()
        || validMatchEndRescueUpdate(roomId);
    }

    // ─── Members (Participant presence) ───────────────────────────────
    function validMemberPresence() {
      return request.resource.data.keys().hasOnly([
        'nickname',
        'role',
        'reportedAtUtc',
        'proximityBand',
        'locationVisibility',
        'preferredRole',
        'preferredSkills',
        'werewolfOniForm',
        'avatarThumbB64',
        'prepReady',
        'appLifecycle',
        'backgroundSinceUtc',
      ]);
    }

    match /rooms/{roomId}/members/{memberId} {
      allow read: if signedIn();
      allow create, update: if isMemberOwner(memberId) && validMemberPresence();
      allow delete: if isMemberOwner(memberId);
    }

    // ─── Room events (Replay / Accusation / SafeZone / Capture zone) ──
    function isEventRoomHost(roomId) {
      return signedIn()
        && roomExists(roomId)
        && request.auth.uid == roomHostUid(roomId);
    }

    function participantRoomEventType(t) {
      return t == 'reveal'
        || t == 'anonymous_reveal'
        || t == 'fake_intel_reveal'
        || t == 'info_broker'
        || t == 'oni_info_broker'
        || t == 'player_eliminated'
        || t == 'accusation_attempt'
        || t == 'accusation_failed'
        || t == 'camera_jack'
        || t == 'facility_sabotage'
        || t == 'spectral_territory'
        || t == 'camera_shutdown'
        || t == 'match_event'
        || t == 'capture_zone_placed'
        || t == 'capture_zone_ack'
        || t == 'abort_vote'
        || t == 'abort_proposal'
        || t == 'abort_majority'
        || t == 'safe_zone_pickup'
        || t == 'accusation_point_scored'
        || t == 'lobby_play_area_proposal'
        || t == 'match_end_rescue'
        || t == 'accusation_unlocked_rescue'
        || t == 'capture_zone_bound_rescue'
        || t == 'player_eliminated_rescue'
        || t == 'oni_capture_elimination';
    }

    function hostOnlyRoomEventType(t) {
      return t == 'capture_zone_bound'
        || t == 'match_start'
        || t == 'match_end'
        || t == 'accusation_unlocked'
        || t == 'lobby_play_area';
    }

    function allowedRoomEventType(roomId, t) {
      return (isEventRoomHost(roomId) && hostOnlyRoomEventType(t))
        || participantRoomEventType(t);
    }

    function validRoomEventCreate(roomId) {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'type',
          'payload',
          'emittedAtUtc',
          'emittedAtMs',
          'actorUid',
          'sessionKey'
        ])
        && d.type is string
        && d.actorUid == request.auth.uid
        && d.emittedAtUtc is string
        && d.emittedAtMs is int
        && d.sessionKey is int
        && d.emittedAtUtc.size() <= 48
        && d.payload is map
        && d.payload.size() <= 32
        && allowedRoomEventType(roomId, d.type)
        && (d.type != 'player_eliminated'
            || isEventRoomHost(roomId)
            || (d.payload.uid is string && d.payload.uid == request.auth.uid))
        && (d.type != 'player_eliminated_rescue'
            || (d.payload.uid is string && d.payload.uid != request.auth.uid))
        && (d.type != 'oni_capture_elimination'
            || (d.payload.uid is string && d.payload.uid != request.auth.uid));
    }

    match /rooms/{roomId}/events/{eventId} {
      allow read: if signedIn();
      allow create: if signedIn() && validRoomEventCreate(roomId);
      allow update, delete: if false;
    }

    // ─── Inspector feed (Spectator read-only GPS summary) ─────────────
    function validInspectorFeedWrite(roomId, memberId) {
      let d = request.resource.data;
      return signedIn()
        && request.auth.uid == memberId
        && memberExists(roomId, memberId)
        && memberRole(roomId, memberId) != 'spectator'
        && roomPhaseRunning(roomId)
        && d.keys().hasOnly([
          'lat',
          'lng',
          'nickname',
          'role',
          'reportedAtUtc'
        ])
        && d.lat is number
        && d.lng is number
        && d.nickname is string
        && d.role is string
        && d.reportedAtUtc is string;
    }

    match /rooms/{roomId}/inspectorFeed/{memberId} {
      allow read: if signedIn() && isRoomSpectator(roomId);
      allow create, update: if validInspectorFeedWrite(roomId, memberId);
      allow delete: if signedIn() && request.auth.uid == memberId;
    }

    // ─── Match archives (Replay upload / Gallery download) ────────────
    function validMatchArchiveWrite(roomId, archiveId) {
      let d = request.resource.data;
      return isRoomParticipant(roomId)
        && d.keys().hasAll(['kind', 'sessionKey', 'uploadedByUid'])
        && d.uploadedByUid == request.auth.uid
        && d.sessionKey is int
        && (
          (d.kind == 'chunk'
            && archiveId == 'chunk_' + string(d.sessionKey) + '_' + request.auth.uid)
          || (d.kind == 'meta'
            && archiveId == 'meta_' + string(d.sessionKey) + '_' + request.auth.uid)
          || (d.kind == 'full' && isEventRoomHost(roomId))
        );
    }

    match /rooms/{roomId}/matchArchives/{archiveId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && validMatchArchiveWrite(roomId, archiveId);
      allow delete: if false;
    }
  }
}
